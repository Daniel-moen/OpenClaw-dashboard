# --- Backend (FastAPI) ---

# Single-user admin password (required). Set this before first run.
ADMIN_PASSWORD=changeme-please

# Long random string used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-with-long-random-string

# Origin allowed by CORS. The SvelteKit dev server defaults to this.
FRONTEND_ORIGIN=http://localhost:5173

# Vault upload limits
MAX_UPLOAD_MB=25

# JobCarver stats source. If unset, the backend falls back to a typed mock so
# the UI stays fully usable. Point this at the existing JobCarver stats API
# whenever you're ready.
JOBCARVER_STATS_URL=
JOBCARVER_STATS_TOKEN=

# Where SQLite + uploads live (relative to backend/). Change for prod.
DATA_DIR=data

# --- Chat with Mia (optional) ---
# Any OpenAI-compatible endpoint works: OpenAI, OpenRouter, Together, local
# Ollama (http://localhost:11434/v1), etc. Leave OPENAI_API_KEY empty to keep
# the chat UI usable in offline mode (messages are still persisted).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
ASSISTANT_NAME=Mia

# --- Frontend (SvelteKit) ---

# Base URL of the FastAPI backend the frontend talks to.
PUBLIC_API_BASE=http://localhost:8000
